# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Email (Gmail App Password recommended) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create a bot via @BotFather and paste the token below.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Only needed by the standalone scanner.py prototype:
TELEGRAM_CHAT_ID=

# ── Anthropic (Claude) — used to generate per-play AI analysis ────────────────
# Without this the scanner falls back to a mechanical summary.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase Cloud Messaging (push notifications) ─────────────────────────────
# Paste the *contents* of the service-account JSON file as a single line.
# Without this push notifications are silently disabled.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Admin / owner ─────────────────────────────────────────────────────────────
ADMIN_KEY=change_this_to_something_secret
OWNER_EMAIL=you@example.com
OWNER_API_KEY=frt_set_a_long_random_string_here

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite by default — point DB_PATH at a persistent volume in production.
DB_PATH=/data/fortress.db
# Optional: set DATABASE_URL to switch to Postgres.
# DATABASE_URL=postgres://user:pass@host:5432/fortress

# ── Hosting ───────────────────────────────────────────────────────────────────
# Render sets RENDER_EXTERNAL_URL automatically; set it manually elsewhere so
# the keep-alive ping can hit a real public URL.
# RENDER_EXTERNAL_URL=https://fortress-options.onrender.com
PORT=8001

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
