{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Fortress Options Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Screenshots Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "4321", "website/screenshots"],
      "port": 4321
    },
    {
      "name": "Fortress Website",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "4322", "website"],
      "port": 4322
    }
  ]
}
