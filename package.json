{
  "name": "fortress-options",
  "private": true,
  "version": "2.4.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "android:init": "npx cap add android",
    "android:sync": "vite build && npx cap sync android",
    "android:open": "npx cap open android",
    "desktop:dev": "NODE_ENV=development electron electron/main.js",
    "desktop:build": "vite build && electron-builder --win --publish never",
    "desktop:build:mac": "vite build && electron-builder --mac --publish never",
    "desktop:build:linux": "vite build && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.fortress.options.desktop",
    "productName": "Fortress Options",
    "icon": "fortress-512.png",
    "directories": {
      "output": "dist_electron2"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "fortress-512.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "fortress-512.png",
      "publish": {
        "provider": "generic",
        "url": "https://github.com/AntonioTate0007/fortress-options/releases/download/windows-latest/"
      }
    },
    "mac": {
      "target": "dmg",
      "icon": "fortress-512.png",
      "category": "public.app-category.finance",
      "artifactName": "fortress-options.dmg",
      "publish": {
        "provider": "generic",
        "url": "https://github.com/AntonioTate0007/fortress-options/releases/download/mac-latest/"
      }
    },
    "linux": {
      "target": "AppImage",
      "icon": "fortress-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "fortress-options-setup.exe"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "@aparajita/capacitor-biometric-auth": "^7.2.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/push-notifications": "^6.0.5",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
