<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0B"
    android:padding="12dp">

    <!-- Header: 🏰 FORTRESS -->
    <TextView
        android:id="@+id/widget_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:text="🏰 FORTRESS"
        android:textColor="#10B981"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:fontFamily="sans-serif-medium" />

    <!-- Hot/Play badge -->
    <TextView
        android:id="@+id/widget_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:text="⚡ PLAY"
        android:textColor="#10B981"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@drawable/widget_badge_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp" />

    <!-- Symbol (large, centered) -->
    <TextView
        android:id="@+id/widget_symbol"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_below="@id/widget_header"
        android:layout_marginTop="2dp"
        android:text="—"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black" />

    <!-- Score -->
    <TextView
        android:id="@+id/widget_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_symbol"
        android:layout_alignParentStart="true"
        android:text="No plays yet"
        android:textColor="#A1A1AA"
        android:textSize="11sp" />

    <!-- Open app button -->
    <TextView
        android:id="@+id/widget_open"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:text="Open App →"
        android:textColor="#10B981"
        android:textSize="11sp"
        android:textStyle="bold" />

</RelativeLayout>
